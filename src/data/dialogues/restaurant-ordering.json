  "itemDialogues": {
    "mesa": {
      "itemId": "mesa",
      "audioKey": "scene.restaurant-ordering.item.mesa",
      "steps": [
        {
          "id": "mesa-step-1",
          "lines": [
            {
              "id": "mesa-1",
              "audioKey": "scene.restaurant-ordering.line.mesa-1",
              "speaker": "Cliente",
              "es": "Buenas tardes, tiene una mesa para dos?",
              "en": "Good afternoon, do you have a table for two?"
            },
            {
              "id": "mesa-2",
              "audioKey": "scene.restaurant-ordering.line.mesa-2",
              "speaker": "Anfitrion",
              "es": "Si, claro. Prefieren adentro o afuera?",
              "en": "Yes, of course. Do you prefer inside or outside?"
            }
          ],
          "responseExercise": {
            "prompt": "The host asks if you prefer inside or outside. Choose a natural answer.",
            "choices": [
              {
                "id": "mesa-step1-choice-1",
                "text": "Adentro, por favor.",
                "rating": "appropriate",
                "feedback": "Great fit. Clear and polite for seating."
              },
              {
                "id": "mesa-step1-choice-2",
                "text": "No se, cualquier cosa.",
                "rating": "acceptable",
                "feedback": "Understandable, but less clear than choosing directly."
              },
              {
                "id": "mesa-step1-choice-3",
                "text": "La mesa bebe agua.",
                "rating": "off_target",
                "feedback": "Off-target for this seating question."
              }
            ]
          }
        },
        {
          "id": "mesa-step-2",
          "lines": [
            {
              "id": "mesa-3",
              "audioKey": "scene.restaurant-ordering.line.mesa-3",
              "speaker": "Cliente",
              "es": "Adentro, por favor.",
              "en": "Inside, please."
            },
            {
              "id": "mesa-4",
              "audioKey": "scene.restaurant-ordering.line.mesa-4",
              "speaker": "Anfitrion",
              "es": "Perfecto, siganme. Esta mesa esta libre.",
              "en": "Perfect, follow me. This table is available."
            }
          ],
          "responseExercise": {
            "prompt": "The host says your table is ready. Pick a polite response.",
            "choices": [
              {
                "id": "mesa-step2-choice-1",
                "text": "Gracias, aqui esta perfecto.",
                "rating": "appropriate",
                "feedback": "Great fit. Natural and polite."
              },
              {
                "id": "mesa-step2-choice-2",
                "text": "Prefiero esperar otra mesa.",
                "rating": "acceptable",
                "feedback": "Understandable, but less cooperative in this flow."
              },
              {
                "id": "mesa-step2-choice-3",
                "text": "La silla llega en autobus.",
                "rating": "off_target",
                "feedback": "Off-target for this moment."
              }
            ]
          }
        }
      ]
    },
    "menu": {
