              "speaker": "Persona B",
              "es": "Si, me gusta mucho la ciudad.",
              "en": "Yes, I really like the city."
            }
          ],
          "responseExercise": {
            "prompt": "You are asked if you like living here. Pick the most natural response.",
            "choices": [
              {
                "id": "origen-step2-choice-1",
                "text": "Si, me gusta mucho la ciudad.",
                "rating": "appropriate",
                "feedback": "Great fit. Natural positive follow-up."
              },
              {
                "id": "origen-step2-choice-2",
                "text": "Mas o menos.",
                "rating": "acceptable",
                "feedback": "Understandable and valid, but less detailed."
              },
              {
                "id": "origen-step2-choice-3",
                "text": "La ciudad come menu.",
