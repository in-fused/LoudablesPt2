  "itemDialogues": {
    "introduccion": {
      "itemId": "introduccion",
      "audioKey": "scene.social-small-talk.item.introduccion",
      "steps": [
        {
          "id": "introduccion-step-1",
          "lines": [
            {
              "id": "introduccion-1",
              "audioKey": "scene.social-small-talk.line.introduccion-1",
              "speaker": "Persona A",
              "es": "Hola, mucho gusto.",
              "en": "Hi, nice to meet you."
            },
            {
              "id": "introduccion-2",
              "audioKey": "scene.social-small-talk.line.introduccion-2",
              "speaker": "Persona B",
              "es": "Igualmente, encantado de conocerte.",
              "en": "Likewise, pleased to meet you."
            }
          ],
          "responseExercise": {
            "prompt": "Someone says: 'Hola, mucho gusto.' Choose a natural social response.",
            "choices": [
              {
                "id": "introduccion-step1-choice-1",
                "text": "Igualmente, encantado de conocerte.",
                "rating": "appropriate",
                "feedback": "Great fit. Polite and common in first meetings."
              },
              {
                "id": "introduccion-step1-choice-2",
                "text": "Si, gracias.",
                "rating": "acceptable",
                "feedback": "Understandable, but less warm and specific."
              },
              {
                "id": "introduccion-step1-choice-3",
                "text": "La introduccion toma cafe.",
                "rating": "off_target",
                "feedback": "Off-target for this greeting."
              }
            ]
          }
        },
        {
          "id": "introduccion-step-2",
          "lines": [
            {
              "id": "introduccion-3",
              "audioKey": "scene.social-small-talk.line.introduccion-3",
              "speaker": "Persona A",
              "es": "Es tu primera vez en este evento?",
              "en": "Is this your first time at this event?"
            },
            {
              "id": "introduccion-4",
              "audioKey": "scene.social-small-talk.line.introduccion-4",
              "speaker": "Persona B",
              "es": "Si, es mi primera vez aqui.",
              "en": "Yes, it is my first time here."
            }
          ],
          "responseExercise": {
            "prompt": "You are asked if this is your first time at the event. Pick the best answer.",
            "choices": [
              {
                "id": "introduccion-step2-choice-1",
                "text": "Si, es mi primera vez aqui.",
                "rating": "appropriate",
                "feedback": "Great fit. Clear and natural."
              },
              {
                "id": "introduccion-step2-choice-2",
                "text": "No estoy seguro.",
                "rating": "acceptable",
                "feedback": "Understandable, but less informative."
              },
              {
                "id": "introduccion-step2-choice-3",
                "text": "El evento vive en la cocina.",
                "rating": "off_target",
                "feedback": "Off-target for this question."
              }
            ]
          }
        }
      ]
    },
    "nombre": {
