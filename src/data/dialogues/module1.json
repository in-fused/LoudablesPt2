          "responseExercise": {
            "prompt": "Your host says: 'Bienvenida a la casa.' What is a good response?",
            "choices": [
              {
                "id": "casa-choice-1",
                "text": "Gracias, qué casa tan bonita.",
                "rating": "appropriate",
                "feedback": "Great fit. You responded politely and stayed on the arrival topic."
              },
              {
                "id": "casa-choice-2",
                "text": "Sí, quiero agua, por favor.",
