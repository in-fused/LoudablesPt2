    "saludo-barrio": {
      "itemId": "saludo-barrio",
      "audioKey": "scene.listening-module.line.hola-cristina",
      "steps": [
        {
          "id": "saludo-barrio-step-1",
          "lines": [
            {
              "id": "saludo-barrio-1",
              "audioKey": "scene.listening-module.line.hola-cristina",
              "speaker": "Amiga",
              "es": "¡Hola, Cristina! Qué bueno verte.",
              "en": "Hi, Cristina! Great to see you."
            }
          ],
          "responseExercise": {
            "prompt": "Your friend greets you warmly. What is a natural response?",
            "choices": [
              {
                "id": "saludo-barrio-step1-choice-1",
                "text": "¡Hola! Todo bien, ¿y tú?",
                "rating": "appropriate",
                "feedback": "Perfect. Warm and very natural for a casual PR greeting."
              },
              {
                "id": "saludo-barrio-step1-choice-2",
                "text": "Buenos días, señora.",
                "rating": "acceptable",
                "feedback": "Correct Spanish, but it sounds too formal for this moment."
              },
              {
                "id": "saludo-barrio-step1-choice-3",
                "text": "La casa está abierta.",
                "rating": "off_target",
                "feedback": "Off-target for a greeting exchange."
              }
            ]
          }
        },
        {
          "id": "saludo-barrio-step-2",
          "lines": [
            {
              "id": "saludo-barrio-2",
              "audioKey": "scene.listening-module.line.hola-cristina",
              "speaker": "Tú",
              "es": "¡Hola! Todo bien, ¿y tú?",
              "en": "Hi! I'm good, and you?"
            },
            {
              "id": "saludo-barrio-3",
              "audioKey": "scene.listening-module.line.hola-cristina",
              "speaker": "Amiga",
              "es": "Todo tranquilo, gracias.",
              "en": "All good, thanks."
            }
          ],
          "responseExercise": {
            "prompt": "She says everything is fine. Choose a friendly follow-up.",
            "choices": [
              {
                "id": "saludo-barrio-step2-choice-1",
                "text": "Qué bueno, me alegro.",
                "rating": "appropriate",
                "feedback": "Great fit. Short, warm, and natural."
              },
              {
                "id": "saludo-barrio-step2-choice-2",
                "text": "Necesito la información completa.",
                "rating": "acceptable",
                "feedback": "Understandable, but it changes topic too quickly."
              },
              {
                "id": "saludo-barrio-step2-choice-3",
                "text": "La puerta está en la mesa.",
                "rating": "off_target",
                "feedback": "Off-target for this conversation."
              }
            ]
          }
        }
      ]
    },
    "cierre-amistoso": {
      "itemId": "cierre-amistoso",
      "audioKey": "scene.listening-module.line.nos-vemos-mas-tarde-gracias",
